# Blockfrost API Configuration
# Get your API key from: https://blockfrost.io
BLOCKFROST_API_KEY=preprodYOUR_API_KEY_HERE

# Wallet Seed Phrase (24 words)
# Generate a new one or use an existing testnet wallet
WALLET_SEED="word1 word2 word3 ... word24"

# TestUSDM Configuration (after minting)
TESTUSDM_POLICY_ID=
TESTUSDM_ASSET_ID=

# Network (Preprod or Preview)
NETWORK=Preprod

# Optional: Faucet Configuration
FAUCET_PORT=3000
FAUCET_AMOUNT=1000000000
MAX_REQUESTS_PER_DAY=5
